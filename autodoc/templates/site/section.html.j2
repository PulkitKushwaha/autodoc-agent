<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ section_title }} — {{ project_name }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px; line-height: 1.7;
      color: #1a1a1a; background: #f8f8f7;
    }
    .sidebar {
      position: fixed; top: 0; left: 0; bottom: 0;
      width: 240px; background: #1a1a1a; padding: 2rem 1.5rem;
      overflow-y: auto;
    }
    .sidebar h1 {
      color: #fff; font-size: 14px; font-weight: 600;
      margin-bottom: 1.5rem; line-height: 1.4;
    }
    .sidebar nav a {
      display: block; color: #9ca3af; text-decoration: none;
      font-size: 13px; padding: 6px 0;
      border-bottom: 1px solid #2d2d2d; transition: color 0.15s;
    }
    .sidebar nav a:hover, .sidebar nav a.active { color: #fff; }
    .sidebar nav a:last-child { border-bottom: none; }
    .main { margin-left: 240px; padding: 3rem 4rem; max-width: 860px; }
    .breadcrumb {
      font-size: 13px; color: #9ca3af; margin-bottom: 2rem;
    }
    .breadcrumb a { color: #6366f1; text-decoration: none; }
    .score-info {
      display: inline-flex; align-items: center; gap: 8px;
      background: #ecfdf5; border: 1px solid #6ee7b7;
      border-radius: 6px; padding: 6px 14px;
      font-size: 13px; color: #065f46; margin-bottom: 1.5rem;
    }
    h1 {
      font-size: 28px; font-weight: 700; margin-bottom: 1.5rem;
      padding-bottom: 1rem; border-bottom: 2px solid #e5e5e5;
    }
    h2 { font-size: 20px; font-weight: 600; margin: 2rem 0 0.75rem; }
    h3 { font-size: 16px; font-weight: 600; margin: 1.5rem 0 0.5rem; }
    h4 { font-size: 14px; font-weight: 600; margin: 1rem 0 0.5rem; }
    p { margin-bottom: 1rem; }
    code {
      font-family: "JetBrains Mono", "Fira Code", Menlo, monospace;
      font-size: 13px; background: #f1f0ee;
      padding: 2px 6px; border-radius: 4px;
    }
    pre {
      background: #1a1a1a; color: #e5e5e5;
      padding: 1.25rem 1.5rem; border-radius: 8px;
      overflow-x: auto; margin: 1rem 0;
      font-size: 13px; line-height: 1.6;
    }
    pre code { background: none; padding: 0; color: inherit; }
    table {
      width: 100%; border-collapse: collapse;
      margin: 1rem 0; font-size: 14px;
    }
    th {
      background: #f1f0ee; text-align: left;
      padding: 8px 12px; font-weight: 600;
      border-bottom: 2px solid #e5e5e5;
    }
    td { padding: 8px 12px; border-bottom: 1px solid #e5e5e5; }
    tr:last-child td { border-bottom: none; }
    .content a { color: #6366f1; }
    .footer {
      margin-top: 3rem; padding-top: 1.5rem;
      border-top: 1px solid #e5e5e5;
      font-size: 12px; color: #9ca3af;
    }
    .footer a { color: #6366f1; text-decoration: none; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <h1>{{ project_name }}</h1>
    <nav>
      <a href="index.html">Overview</a>
      {% for section in all_sections %}
      <a
        href="{{ section.filename }}"
        class="{{ 'active' if section.title == section_title else '' }}"
      >{{ section.title }}</a>
      {% endfor %}
    </nav>
  </aside>

  <main class="main">
    <div class="breadcrumb">
      <a href="index.html">{{ project_name }}</a> / {{ section_title }}
    </div>

    {% if score %}
    <div class="score-info">
      &#10003; Quality score: {{ score }}/10
    </div>
    {% endif %}

    <div class="content">
      {{ content_html | safe }}
    </div>

    <div class="footer">
      Generated by
      <a href="https://github.com/yourusername/autodoc-agent">AutoDoc</a>
    </div>
  </main>
</body>
</html>
