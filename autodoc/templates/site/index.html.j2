<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ project_name }} — documentation</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px; line-height: 1.6;
      color: #1a1a1a; background: #f8f8f7;
    }
    .sidebar {
      position: fixed; top: 0; left: 0; bottom: 0;
      width: 240px; background: #1a1a1a; padding: 2rem 1.5rem;
      overflow-y: auto;
    }
    .sidebar h1 {
      color: #fff; font-size: 14px; font-weight: 600;
      margin-bottom: 1.5rem; line-height: 1.4;
    }
    .sidebar nav a {
      display: block; color: #9ca3af; text-decoration: none;
      font-size: 13px; padding: 6px 0;
      border-bottom: 1px solid #2d2d2d; transition: color 0.15s;
    }
    .sidebar nav a:hover { color: #fff; }
    .sidebar nav a:last-child { border-bottom: none; }
    .main { margin-left: 240px; padding: 3rem 4rem; max-width: 900px; }
    .hero {
      margin-bottom: 3rem; padding-bottom: 2rem;
      border-bottom: 1px solid #e5e5e5;
    }
    .hero h2 { font-size: 28px; font-weight: 600; margin-bottom: 8px; }
    .hero p { color: #6b7280; font-size: 15px; }
    .section-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }
    .section-card {
      background: #fff; border: 1px solid #e5e5e5; border-radius: 8px;
      padding: 1.25rem 1.5rem; text-decoration: none; color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .section-card:hover {
      border-color: #6366f1;
      box-shadow: 0 2px 8px rgba(99, 102, 241, 0.1);
    }
    .section-card h3 {
      font-size: 15px; font-weight: 600; margin-bottom: 6px;
    }
    .section-card p { font-size: 13px; color: #6b7280; }
    .score-badge {
      display: inline-block; font-size: 11px; font-weight: 600;
      padding: 2px 8px; border-radius: 12px; margin-top: 10px;
      background: #ecfdf5; color: #065f46;
    }
    .footer {
      margin-top: 3rem; padding-top: 1.5rem;
      border-top: 1px solid #e5e5e5;
      font-size: 12px; color: #9ca3af;
    }
    .footer a { color: #6366f1; text-decoration: none; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <h1>{{ project_name }}</h1>
    <nav>
      <a href="index.html">Overview</a>
      {% for section in sections %}
      <a href="{{ section.filename }}">{{ section.title }}</a>
      {% endfor %}
    </nav>
  </aside>

  <main class="main">
    <div class="hero">
      <h2>{{ project_name }}</h2>
      <p>Technical documentation &mdash; generated {{ generated_at }}</p>
    </div>

    <div class="section-grid">
      {% for section in sections %}
      <a class="section-card" href="{{ section.filename }}">
        <h3>{{ section.title }}</h3>
        <p>{{ section.preview }}</p>
        {% if section.score %}
        <span class="score-badge">quality {{ section.score }}/10</span>
        {% endif %}
      </a>
      {% endfor %}
    </div>

    <div class="footer">
      Generated by
      <a href="https://github.com/yourusername/autodoc-agent">AutoDoc</a>
    </div>
  </main>
</body>
</html>
