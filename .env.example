# This is an example file to replicate .env in your project if you are referencing this

# Anthropic API key
# Leave empty when using mock mode
ANTHROPIC_API_KEY=

# Set to true to use mock LLM responses (use this if you do not have API keys but still want to understand the working of this project)
# Set to false if you have your API keys
AUTODOC_USE_MOCK=true

# Output directory for generated documentation
AUTODOC_OUTPUT_DIR=./output

# Temporary directory for cloning GitHub repos
AUTODOC_TEMP_DIR=./temp_repos

# Logging level: DEBUG, INFO, WARNING, ERROR
AUTODOC_LOG_LEVEL=INFO

# Log file path — leave empty to disable file logging
AUTODOC_LOG_FILE=./output/autodoc.log
